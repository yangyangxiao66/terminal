{
  "name": "terminal-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop terminal multiplexer powered by ConPTY.",
  "author": "yangyangxiao66",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check preload-pet.js && node --check renderer/app.js && node --check renderer/pet.js && node --check scripts/afterPack.js",
    "install-desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-desktop-shortcut.ps1",
    "dist:win": "npm run check && electron-builder --win portable --x64",
    "dist:win:all": "npm run check && electron-builder --win nsis portable --x64",
    "dist:win:setup": "npm run check && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "build": {
    "appId": "io.github.yangyangxiao66.terminaldeck",
    "productName": "某걶삞麵뾀땻",
    "npmRebuild": false,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "afterPack": "./scripts/afterPack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-pet.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "terminal-deck-setup-v${version}-windows-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "某걶삞麵뾀땻",
      "differentialPackage": false
    },
    "portable": {
      "artifactName": "terminal-deck-portable-v${version}-windows-${arch}.${ext}"
    }
  }
}
